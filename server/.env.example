# ═══════════════════════════════════════════════════════
# SUPABASE DATABASE
# ═══════════════════════════════════════════════════════
# Go to: https://supabase.com → Your Project → Settings → Database
# 
# Connection Pooling (Transaction Mode) - for app queries:
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct Connection - for Prisma migrations:
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ═══════════════════════════════════════════════════════
# JWT SECRETS
# ═══════════════════════════════════════════════════════
JWT_SECRET="your-jwt-secret-here-change-in-production-must-be-64-chars-long"
REFRESH_TOKEN_SECRET="your-refresh-secret-here-change-in-production-must-be-64-chars"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# ═══════════════════════════════════════════════════════
# QR ENCRYPTION (32-byte hex key = 64 hex characters)
# ═══════════════════════════════════════════════════════
QR_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# ═══════════════════════════════════════════════════════
# SERVER
# ═══════════════════════════════════════════════════════
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# ═══════════════════════════════════════════════════════
# CLEANUP
# ═══════════════════════════════════════════════════════
DELIVERY_EXPIRY_DAYS=7
